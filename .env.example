# Telegram
BOT_TOKEN=
ALLOWED_USER_ID=

# OpenRouter (LLM)
OPENROUTER_API_KEY=

# Langfuse
PROMPT_NAME=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Postgres — must point at a role that can only SELECT (see README/docs for
# how to create the read-only role). Add ?sslmode=require if connecting over
# the public internet.
DATABASE_URL=postgresql+psycopg2://bot_readonly:CHANGEME@db:5432/DBNAME
